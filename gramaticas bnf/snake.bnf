<programa> ::= <tipo_juego> <grid> <definiciones> <eventos>

<tipo_juego> ::= "GAME_TYPE" "SNAKE"
<grid>       ::= "GAME_GRID" "(" <numero> "," <numero> ")"
<definiciones> ::= <definicion> | <definicion> <definiciones>
<definicion> ::= <definicion_shape> | <definicion_geometria_serpiente>

<definicion_shape> ::= "DEFINE" "SHAPE" <identificador> ":" <estados> "END"
<definicion_geometria_serpiente> ::= "SNAKE_SHAPE" <tipo_geometria>
<tipo_geometria> ::= "SQUARE" | "CIRCULAR" | "TRIANGULAR"
<eventos>    ::= <evento> | <evento> <eventos>

<definicion_shape> ::= "DEFINE" "SHAPE" <identificador> ":" <estados> "END"
<estados>          ::= <estado> | <estado> <estados>
<estado>           ::= "STATE" <numero> ":" <matriz>
<matriz>           ::= <fila> | <fila> <matriz>
<fila>             ::= "[" <valores_fila> "]"
<valores_fila>     ::= <numero> | <numero> "," <valores_fila>

<evento>         ::= "ON" <nombre_evento_snake> ":" <acciones_snake> "END"
<nombre_evento_snake> ::= "START" | "TICK" | "EAT_FOOD" | "COLLISION_WALL" | "COLLISION_SELF" | "KEY_UP" | "KEY_DOWN" | "KEY_LEFT" | "KEY_RIGHT" | "EAT_POISON" | "COLLISION_OBSTACLE" | "EAT_INVINCIBLE"
<acciones_snake>     ::= <accion_snake> | <accion_snake> <acciones_snake>

<accion_snake> ::= <accion_spawn_jugador> | <accion_spawn_comida> | <accion_mover> | <accion_direccion> | <accion_puntos> | <accion_crecer> | <accion_gameover> | <accion_spawn_veneno> | <accion_spawn_obstaculo> | <accion_spawn_powerup> | <accion_quitar_puntos> | <accion_perder_todo> | <accion_invencible>

<accion_spawn_jugador> ::= "SPAWN" "PLAYER" "AT" <coordenadas>
<accion_spawn_comida>  ::= "SPAWN" "FOOD" "AT" "RANDOM"
<accion_spawn_veneno>  ::= "SPAWN" "POISON" "AT" "RANDOM"
<accion_spawn_obstaculo> ::= "SPAWN" "OBSTACLE" "AT" "RANDOM"
<accion_spawn_powerup> ::= "SPAWN" "POWERUP_INVINCIBLE" "AT" "RANDOM"

<accion_mover>         ::= "MOVE" "PLAYER" "FORWARD"
<accion_direccion>     ::= "SET_DIRECTION" <direccion>
<accion_puntos>        ::= "INCREASE_SCORE" <numero>
<accion_quitar_puntos> ::= "DECREASE_SCORE" <numero>
<accion_perder_todo>   ::= "LOSE_ALL_SCORE"
<accion_crecer>        ::= "GROW" "PLAYER" <numero>
<accion_invencible>    ::= "MAKE_INVINCIBLE" <numero>
<accion_gameover>      ::= "GAME_OVER"

<coordenadas>   ::= "(" <numero> "," <numero> ")"
<direccion>     ::= "UP" | "DOWN" | "LEFT" | "RIGHT"
<identificador> ::= <letra> | <letra> <identificador>
<numero>        ::= <digito> | <digito> <numero>
<letra>         ::= "A"..."Z" | "_"
<digito>        ::= "0"..."9"